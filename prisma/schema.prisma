// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  projects     Project[]
  resources    Resource[]
  tags         Tag[]
  activityLogs ActivityLog[]
  sessions     Session[]

  @@index([id])
}

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       Status        @default(ACTIVE)
  user         User          @relation(fields: [userId], references: [id])
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  resources    Resource[]
  activityLogs ActivityLog[]
  deletedAt    DateTime?

  @@unique([userId, name])
  @@index([userId])
}

model Resource {
  id           String        @id @default(cuid())
  title        String
  description  String?
  type         ResourceType
  content      String?
  externalLink String?
  user         User          @relation(fields: [userId], references: [id])
  userId       String
  project      Project       @relation(fields: [projectId], references: [id])
  projectId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  file         File?
  resourceTags ResourceTag[]
  activityLogs ActivityLog[]
  deletedAt    DateTime?

  @@unique([userId,title,type])
  @@index([userId])
  @@index([projectId])
  @@index([type])
}

model File {
  id         String   @id @default(cuid())
  resource   Resource @relation(fields: [resourceId], references: [id])
  resourceId String @unique
  fileName   String
  fileURL    String
  mimeType   String
  fileSize   Int
  createdAt  DateTime @default(now())

  @@index([resourceId])
}

model Tag {
  id           String        @id @default(cuid())
  name         String
  user         User          @relation(fields: [userId], references: [id])
  userId       String
  createdAt    DateTime      @default(now())
  resourceTags ResourceTag[]

  @@unique([userId, name])
}

model ResourceTag {
  resource   Resource @relation(fields: [resourceId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])
  resourceId String
  tagId      String

  @@id([resourceId, tagId])
}

model ActivityLog {
  id         String       @id @default(cuid())
  actionType ActivityType
  user       User         @relation(fields: [userId], references: [id])
  userId     String
  resource   Resource?    @relation(fields: [resourceId], references: [id])
  project    Project?     @relation(fields: [projectId], references: [id])
  resourceId String?
  projectId  String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Session {
  sessionId String   @id
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresIn DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum ActivityType {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED
  RESOURCE_CREATED
  RESOURCE_UPDATED
  RESOURCE_DELETED
  FILE_UPLOADED
}

enum ResourceType {
  NOTE
  LINK
  PDF
  IMAGE
}

enum Status {
  ACTIVE
  ARCHIVED
}
